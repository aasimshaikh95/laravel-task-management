							"path": ["tasks"],
							"query": [
								{
									"key": "due_date",
									"value": "2026-04-07",
									"description": "Format: YYYY-MM-DD"
								}
							]
						},
						"description": "List tasks filtered by due date."
					},
					"response": []
				},
