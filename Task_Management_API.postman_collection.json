						"url": {
							"raw": "{{base_url}}/tasks",
							"host": ["{{base_url}}"],
							"path": ["tasks"]
						},
						"description": "List all tasks for the authenticated user (paginated). Admin sees all tasks."
					},
					"response": []
				},
				{
					"name": "List Tasks - Filter by Status",
					"request": {
						"method": "GET",
						"header": [
